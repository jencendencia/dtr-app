{
  "name": "biometric-dtr-app",
  "version": "1.2.4",
  "description": "Biometric Daily Time Record System for Schools",
  "main": "src/main/main.js",
  "author": "DTR System",
  "scripts": {
    "start": "electron .",
    "seed": "node src/db/seed.js",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.dtr.biometric-app",
    "productName": "Biometric DTR System",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "publish": {
      "provider": "github",
      "owner": "jencendencia",
      "repo": "dtr-app",
      "releaseType": "release",
      "token": "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"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Biometric DTR"
    }
  },
  "devDependencies": {
    "electron": "^29.1.5",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "electron-updater": "^6.8.9",
    "xlsx": "^0.18.5"
  }
}
